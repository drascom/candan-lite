# Enviroment variables needed to connect to the LiveKit server.
LIVEKIT_API_KEY=<your_api_key>
LIVEKIT_API_SECRET=<your_api_secret>
LIVEKIT_URL=wss://<project-subdomain>.livekit.cloud

# Preferred Hermes connection: the backend receives both the instance room and
# a room-scoped participant token from the plugin endpoint.
# MATE_TOKEN_ENDPOINT=https://mate-token.drascom.uk
# MATE_VOICE_CLIENT_KEY=<hermes_client_key>

# Direct-mint fallback: keep LIVEKIT_* above and discover only the room/URL.
# MATE_DISCOVERY_ENDPOINT=https://mate-token.drascom.uk

# Agent dispatch (https://docs.livekit.io/agents/server/agent-dispatch)
# Leave AGENT_NAME blank to enable automatic dispatch
# Provide an agent name to enable explicit dispatch
AGENT_NAME=

# Internally used environment variables
NEXT_PUBLIC_APP_CONFIG_ENDPOINT=
SANDBOX_ID=
