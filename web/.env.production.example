# Preferred: Hermes owns the room and mints a room-scoped client token.
MATE_TOKEN_ENDPOINT=https://mate-token.drascom.uk
MATE_VOICE_CLIENT_KEY=replace-with-the-hermes-client-key

# Direct-mint fallback: the web backend owns LiveKit credentials but discovers
# the current Hermes instance room instead of hard-coding it.
# MATE_DISCOVERY_ENDPOINT=https://mate-token.drascom.uk
# LIVEKIT_API_KEY=replace-me
# LIVEKIT_API_SECRET=replace-me
# LIVEKIT_URL=wss://livekit.example.com

WEB_USERNAME=mate
WEB_PASSWORD=replace-with-a-long-random-password
WEB_BIND=127.0.0.1
WEB_PORT=3000
