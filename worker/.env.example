# worker/.env örneği — kopyala: `cp .env.example .env` ve gerçek değerleri gir.
# LiveKit (oracle-stage — web ile AYNI key/secret)
LIVEKIT_URL=wss://mate-livekit.drascom.uk
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
MATE_LIVEKIT_ROOM=candan-lite-dev

# STT/TTS (.25 GPU kutusu — mesh IP)
STT_HOST=192.168.0.25
STT_PORT=10300
TTS_HOST=192.168.0.25
TTS_PORT=8808
MATE_LANGUAGE=tr

# STT backend secimi (additive; varsayilan mevcut davranis).
#   wyoming -> Wyoming/faster-whisper (STT_HOST:STT_PORT). VARSAYILAN, degismedi.
#   moss    -> MOSS-Transcribe-Diarize HTTP servisi (asagidaki MOSS_STT_URL).
# MOSS diarize (speaker etiketi) dondurur; su an transcript duz metin verilir,
# segment/speaker detayi debug log'a yazilir (isim eslemesi ayri faz).
STT_BACKEND=wyoming
MOSS_STT_URL=http://192.168.0.25:8909

# Beyin: pi CLI, warm `--mode rpc` subprocess (docs/pi-brain-design.md).
# HTTP /v1 YOK — port gerekmez. Persona/skill/memory local pi/ + sessions/ ile.
PI_PERSONA_DIR=pi/personas
PI_SKILLS_DIR=pi/skills
PI_SESSION_DIR=sessions
PI_DEFAULT_PERSONA=candan
# Model pinlenmeli: global varsayilan gpt-5.6-luna rpc'de bozuk ("Model not found").
#
# ── UZAK vs YEREL BEYIN — GECIS TEK SATIR ────────────────────────────────────
# UZAK (bulut, varsayilan):   PI_MODEL=openai-codex/gpt-5.6-terra   + PI_THINKING=minimal
# YEREL (.25 GPU kutusu):     PI_MODEL=llama-cpp/gemma-4-12B-it-qat-q4_0  + PI_THINKING=default
#
# YEREL beyin = Gemma-4-12B-it QAT (q4_0), llama-server, .25:8082, OpenAI-uyumlu /v1.
#   Servis: candan-brain.service (systemd, boot'ta aktif). VRAM ~10.1 GB
#   (Whisper 2.4 + TTS 4.7 + moss-diarize 2.0 ile birlikte 19.2/24.5 GB).
#   Saglayici pi'da TANIMLI: ~/.pi/agent/models.json -> providers."llama-cpp"
#     { "baseUrl": "http://192.168.0.25:8082/v1", "api": "openai-completions" }
#   Bu dosya REPO DISI (kullanicinin global pi konfigi). Yeni makinede yeniden yazilmali.
#
#   NEDEN PI_THINKING=default: yerel model reasoning'siz (models.json: reasoning=false,
#   sunucuda --reasoning off). "minimal" desteklenmeyen bir thinking seviyesi zorlar.
#
#   Yerel beyin tool secimini KENDI yapiyor -> onunde ayri bir router modeli YOK
#   (kucuk tool-router + ceviri katmani kaldirildi; her turda ~824 ms vergiydi).
PI_MODEL=llama-cpp/gemma-4-12B-it-qat-q4_0
#PI_MODEL=openai-codex/gpt-5.6-terra
# Gecikme: thinking seviyesi. off daha yavas (~6.6s), minimal en iyi (~2.6s), default ~3.2s.
# Bos veya "default" -> bayrak eklenmez (pi varsayilani). Uzak modelde onerilen: minimal.
# YEREL beyinde "default" OLMALI (model reasoning desteklemiyor).
PI_THINKING=default
#PI_THINKING=minimal
# Tur stall watchdog (saniye): son ilerlemeden bu kadar sure HIC olay gelmezse
# (WebSocket 1000 gibi ~33-40s takilma) tur temiz kapatilir. Normal turlar 3-5s.
PI_TURN_STALL_TIMEOUT=12
# Izolasyon: worker'in pi surecine GLOBAL (~/.pi/agent) extension/skill/prompt/theme/
# context-file KESFI kapatilir (-ne -ns -np --no-themes -nc). Kullanicinin kendi global
# pi kurulumu DEGISMEZ; sadece bu surec izole baslar. Lokal olanlar (-e pi/extensions/
# mem/index.ts, --skill pi/skills, --append-system-prompt pi/AGENTS.md + personas)
# explicit verildigi icin AYNEN yuklenir. false -> global her sey tekrar sizar.
PI_ISOLATED=true

# Faz 3: Speaker-ID (ses tanima) — kapaliyken davranis Faz 2 ile AYNI.
# Yollar worker/ kokune gore relative (agent.py cwd = worker/).
SPEAKER_ID_ENABLED=false
SPEAKER_MODEL_PATH=models/campplus.onnx
SPEAKER_MODEL_ID=campplus_zh_en_advanced_v1
SPEAKER_DB=data/speakers.db
SPEAKER_THRESHOLD=0.45
SPEAKER_MARGIN=0.05
SPEAKER_MIN_SECONDS=1.0
SPEAKER_ENROLL_MIN_SECONDS=4.0
# Enroll koruması: yeni kişi açmadan önce ses mevcut kişilere benziyor mu?
#   skor >= SPEAKER_THRESHOLD          → yeni kişi AÇMA, mevcut kişiye örnek ekle
#   SPEAKER_MERGE_LOW <= skor < eşik   → "Sen X misin?" diye sor
#   skor <  SPEAKER_MERGE_LOW          → gerçekten yeni kişi
SPEAKER_MERGE_LOW=0.35
# Artımlı öğrenme (opsiyonel, default kapalı): yüksek güvenli tanımada centroid'i besle
SPEAKER_LEARN_ENABLED=false
SPEAKER_LEARN_MIN_SCORE=0.60
SPEAKER_LEARN_MAX_PER_SESSION=2
SPEAKER_LEARN_COOLDOWN_S=60

# Wake word ("konusma penceresi"): sistem surekli acik, STT her seyi yazar ama
# agent normalde UYUR (cevap vermez). WAKE_WORD duyunca uyanir; bu turdan itibaren
# cevap verir. WAKE_WINDOW_SECONDS sessizlikten sonra tekrar uyur (her etkilesim
# pencereyi sifirlar). WAKE_ENABLED=false -> gate yok (her turda cevap, eski davranis).
WAKE_ENABLED=true
WAKE_WORD=candan
WAKE_WINDOW_SECONDS=15
# Fuzzy/fonetik wake toleransi: Whisper izole "candan"i tutarli sekilde YANLIS
# ceviriyor ("John Don", "John Donne", "Can dan", "Kandan"...) -> wake acilmiyor.
# Bu varyantlar SADECE izole-kisa metne uygulanir (<=2 kelime & <=12 karakter);
# cumle icinde fuzzy UYGULANMAZ (yanlis-pozitif olmasin). Virgulle ayir. Izole wake
# kasitli + dusuk maliyet (sadece can + kisa uyanma) oldugu icin tolerans guvenli.
WAKE_VARIANTS=candan,kandan,canden,candon,johndon,johndonne,jondon,candam

# Paralel erken-wake dinleyici (opsiyonel, additive). Ana AgentSession STT'si tum
# cumleyi bekler; bu acikken mic track'e ayri bir silero-VAD + kisa-pencere Whisper
# baglanir, "candan" duyulur duyulmaz brain.wake_now() ile can HEMEN calar (~200-270ms
# whisper roundtrip). KAPALIYKEN davranis AYNI (bu ek/erken bir yol). Sadece uyurken
# transcribe eder (uyanikken ana STT yeterli). WAKE_STT_WINDOW = erken pencere (sn);
# fizibilitede >=1.0s guvenilir, 0 false-positive olcuLdu.
# WAKE_STT_MAX_SECONDS = segmentin yalnizca ILK bu kadar saniyesi wake taramasina girer.
# Wake kelimesi cumlenin BASINDA soylenir; gerisini Whisper'a vermek saf GPU israfi
# (9 sn'lik cumle eskiden ~40 sn ses isletiyordu). Gerekirse buyutulebilir.
WAKE_STT_ENABLED=false
WAKE_STT_WINDOW=1.5
WAKE_STT_MAX_SECONDS=4.0

# Log gürültüsü kontrolü: 'dev' modu varsayılan DEBUG basar + bazı loglar her
# chunk/pencerede tekrarlanır (ör. speaker-tap "sessiz pencere atlandı"). Varsayılan
# davranış: seviye INFO'ya çekilir + tekrarlayan aynı log LOG_DEDUPE_SECONDS içinde
# yalnızca ilk kez basılır (log_utils.DedupeFilter). Teşhis kaybolmaz: pencere dolunca
# yine basılır, kaç tekrarın bastırıldığı da eklenir.
# WORKER_VERBOSE_LOGS=true  -> eski/ham davranış: DEBUG seviye + dedupe tamamen kapalı.
WORKER_VERBOSE_LOGS=false
# WORKER_LOG_LEVEL=INFO     -> WORKER_VERBOSE_LOGS kapalıyken kullanılan seviye.
# LOG_DEDUPE_SECONDS=30     -> aynı log art arda kaç sn içinde bir kez basılsın.

# ── Proaktif ajan (hatırlatma / bitmiş iş) ────────────────────────────────────
# Hatırlatmaları pi extension (pi/extensions/family-memory) memory/events.db'ye YAZAR;
# worker heartbeat'i vakti geleni okur ve KENDİ BAŞLATARAK seslenir:
#   "Ayhan?" → kullanıcı yanıt verirse → hatırlatmayı iletir (delivered).
#   Cevap yoksa 1 kez daha seslenir, sonra pending'e döner (attempts++) ve RETRY sonra
#   tekrar dener. Kullanıcı KONUŞUYORSA erteler; odada YOKSA hiç seslenmez (pending kalır);
#   UYKUDAYKEN de seslenir (uyku susturmaz).
# PROACTIVE_TICK_SECONDS=20     -> heartbeat periyodu
# PROACTIVE_REPLY_TIMEOUT=8     -> seslenmeden sonra onay için beklenen süre (sn)
# PROACTIVE_RETRY_SECONDS=300   -> cevapsız kalan hatırlatma bu kadar sonra tekrar denenir
# PROACTIVE_LATE_HOURS=12       -> bundan geç iletilen hatırlatma "geçmiş" diye belirtilir
# CANDAN_TZ=Europe/London       -> duvar saati çözümü (due_at'i KOD hesaplar, model değil)
# EVENTS_DB=                    -> olay deposu yolu (varsayılan: <MEM_DIR>/events.db)
# MEM_DIR=                      -> hafıza kökü (test izolasyonu; varsayılan: repo memory/)

# ── Konsolidasyon (bağlam şişmesi) ───────────────────────────────────────────
# profile.md + family.md HER TURDA modele enjekte edilir (bağlam ↔ gecikme ≈ 2.4 ms/KB).
# Sınır aşılınca worker, kullanıcı SESSİZKEN pi'ya sessiz bir tur açar → memory_consolidate:
# kalıcı gerçekler dosyada kalır, olaylar notes/'a iner (notes context'e girmez, FTS'te aranır).
# MEM_CONTEXT_LIMIT_BYTES=2048        -> profile.md / family.md sert sınırı
# CONSOLIDATE_COOLDOWN_SECONDS=86400  -> dosya başına günde en fazla 1 konsolidasyon

# ── Pano (oturum dökümü + salt-okunur hafıza) ────────────────────────────────
#   python3 tools/dashboard.py  → http://127.0.0.1:8765
#
# NOT: Eski küçük tool-router + çeviri katmanı KALDIRILDI (bkz. docs/ROUTER-EXPERIMENTS.md).
# Tool seçimini artık TEK YEREL BEYİN (Gemma-4-12B, candan-brain.service) kendi yapıyor;
# araya bir router modeli sokmak gereksiz vergi ve gereksiz hata kaynağıydı. Ölçüm
# takımı experiments/router-bench/ altında DURUYOR (yeni bir beyni tartmak için).
