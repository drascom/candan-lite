# worker/.env örneği — kopyala: `cp .env.example .env` ve gerçek değerleri gir.
# LiveKit (oracle-stage — web ile AYNI key/secret)
LIVEKIT_URL=wss://mate-livekit.drascom.uk
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
MATE_LIVEKIT_ROOM=candan-lite-dev

# ── Terminal istemcisi (cli_client.py) ────────────────────────────────────────
# Yanki bastirma (AEC). Varsayilan ACIK: hoparlorle konusurken Candan'in kendi sesi
# mikrofona geri girer -> kendini boler, ustelik o ses speaker-ID'ye BILINMEYEN gorunup
# "sen kimsin?" enrollment'ini tetikler. Tarayici bunu getUserMedia({echoCancellation})
# ile bedava aliyordu; CLI ham mikrofon yayinladigi icin WebRTC APM'i elle suruyoruz.
#   MATE_CLI_AEC=0          -> AEC kapali (--no-aec ile ayni). Kulaklikla gereksiz.
#   MATE_CLI_HALF_DUPLEX=1  -> YEDEK yol (--half-duplex): Candan konusurken mikrofon
#                              susturulur. Yankiyi kesin bitirir AMA sozunu kesemezsin.
# NOT: AEC yalnizca 8000/16000/32000/48000 Hz'de calisir (WebRTC APM orani).
#MATE_CLI_AEC=1
#MATE_CLI_HALF_DUPLEX=0
# MATE_CLI_NAME  = LiveKit KATILIMCI ADI (cihazin sahibi). Transkript etiketi DEGIL.
# MATE_CLI_LABEL = transkriptte kullanici satirinin etiketi. NOTR birak ("Sen"):
#   worker konusmaciyi cozuyor (speaker_tap.py) ama odaya YAYMIYOR -> istemci kimin
#   konustugunu BILEMEZ. Buraya sabit bir isim yazmak evdeki HERKESI o isimle etiketler.
#MATE_CLI_NAME=Sen
#MATE_CLI_LABEL=Sen

# STT/TTS (.25 GPU kutusu — mesh IP)
STT_HOST=192.168.0.25
STT_PORT=10300
TTS_HOST=192.168.0.25
TTS_PORT=8808
MATE_LANGUAGE=tr

# STT backend secimi (additive; varsayilan mevcut davranis).
#   wyoming -> Wyoming/faster-whisper (STT_HOST:STT_PORT). VARSAYILAN, degismedi.
#   moss    -> MOSS-Transcribe-Diarize HTTP servisi (asagidaki MOSS_STT_URL).
# MOSS diarize (speaker etiketi) dondurur; su an transcript duz metin verilir,
# segment/speaker detayi debug log'a yazilir (isim eslemesi ayri faz).
STT_BACKEND=wyoming
MOSS_STT_URL=http://192.168.0.25:8909

# Beyin: pi CLI, warm `--mode rpc` subprocess (docs/pi-brain-design.md).
# HTTP /v1 YOK — port gerekmez. Persona/skill/memory local pi/ + sessions/ ile.
PI_PERSONA_DIR=pi/personas
PI_SKILLS_DIR=pi/skills
PI_SESSION_DIR=sessions
PI_DEFAULT_PERSONA=candan
# Model pinlenmeli: global varsayilan gpt-5.6-luna rpc'de bozuk ("Model not found").
#
# ── UZAK vs YEREL BEYIN — GECIS TEK SATIR ────────────────────────────────────
# UZAK (bulut, varsayilan):   PI_MODEL=openai-codex/gpt-5.6-terra   + PI_THINKING=minimal
# YEREL (.25 GPU kutusu):     PI_MODEL=llama-cpp/gemma-4-12B-it-qat-q4_0  + PI_THINKING=default
#
# YEREL beyin = Gemma-4-12B-it QAT (q4_0), llama-server, .25:8082, OpenAI-uyumlu /v1.
#   Servis: candan-brain.service (systemd, boot'ta aktif). VRAM ~10.1 GB
#   (Whisper 2.4 + TTS 4.7 + moss-diarize 2.0 ile birlikte 19.2/24.5 GB).
#   Saglayici pi'da TANIMLI: ~/.pi/agent/models.json -> providers."llama-cpp"
#     { "baseUrl": "http://192.168.0.25:8082/v1", "api": "openai-completions" }
#   Bu dosya REPO DISI (kullanicinin global pi konfigi). Yeni makinede yeniden yazilmali.
#
#   NEDEN PI_THINKING=default: yerel model reasoning'siz (models.json: reasoning=false,
#   sunucuda --reasoning off). "minimal" desteklenmeyen bir thinking seviyesi zorlar.
#
#   Yerel beyin tool secimini KENDI yapiyor -> onunde ayri bir router modeli YOK
#   (kucuk tool-router + ceviri katmani kaldirildi; her turda ~824 ms vergiydi).
PI_MODEL=llama-cpp/gemma-4-12B-it-qat-q4_0
#PI_MODEL=openai-codex/gpt-5.6-terra
# Gecikme: thinking seviyesi. off daha yavas (~6.6s), minimal en iyi (~2.6s), default ~3.2s.
# Bos veya "default" -> bayrak eklenmez (pi varsayilani). Uzak modelde onerilen: minimal.
# YEREL beyinde "default" OLMALI (model reasoning desteklemiyor).
PI_THINKING=default
#PI_THINKING=minimal
# Tur stall watchdog (saniye): son ilerlemeden bu kadar sure HIC olay gelmezse
# (WebSocket 1000 gibi ~33-40s takilma) tur temiz kapatilir. Sicak turlar 0.4-1s.
PI_TURN_STALL_TIMEOUT=12
# SOGUK ILK TUR toleransi (saniye). Taze pi sureci (boot / konusmaci swap / mod swap)
# oturum gecmisini bastan yukler -> llama-server'da KV cache soguk -> prefill 9-17s
# (olculdu: 8717 token / 8.9s). Bu SAGLIKLI bekleme; 12s'lik watchdog onu kesip
# "tekrar dener misin?" yedegini soyletiyordu. Bu deger SADECE surecin ilk
# text_delta'sina kadar gecerlidir; delta gelince watchdog PI_TURN_STALL_TIMEOUT'a
# duser -> gercek takilmalarda hiz kaybi yok.
PI_FIRST_TURN_STALL_TIMEOUT=45
# Soguk yukleme bu saniyeyi gecerse kullaniciya TEK kisa ara soz soylenir (sessiz
# bekletme kotu). 0 -> hic soyleme. Sadece soguk turda, tur basina en fazla bir kez.
PI_COLD_NOTICE_DELAY=5
PI_COLD_NOTICE_TEXT=Bir saniye, aklimi topluyorum.
# Compaction (baglam sikistirma) ara sozu. pi baglam dolunca gecmisi ozetler; ACIL
# DEGILSE bunu tur SONUNA saklar -> cevap zaten soylenmis olur, ara soz gerekmez.
# ACIL halde (baglam tasti, reason=overflow) cevap URETILEMEDEN sikistirma calisir ->
# kullanici sessiz bekler. Ayrimi reason'a gore degil, kullanicinin o turda bir sey
# DUYUP DUYMADIGINA gore yapariz: duyduysa sessiz, duymadiysa bu cumle soylenir.
PI_COMPACTION_NOTICE_TEXT=Bir saniye, aklimi toparliyorum.
# Compaction penceresinde watchdog toleransi (saniye). ZORUNLU: compaction_start ile
# compaction_end arasinda pi HIC olay yaymaz (araya tek bir ozetleme LLM cagrisi
# giriyor) -> 12s'lik normal tolerans SAGLIKLI bir sikistirmayi keser, turu abort
# ederdi. Sikistirma tum baglami ozetler -> dakikayi bulabilir.
PI_COMPACTION_STALL_TIMEOUT=120
# Izolasyon: worker'in pi surecine GLOBAL (~/.pi/agent) extension/skill/prompt/theme/
# context-file KESFI kapatilir (-ne -ns -np --no-themes -nc). Kullanicinin kendi global
# pi kurulumu DEGISMEZ; sadece bu surec izole baslar. Lokal olanlar (-e pi/extensions/
# mem/index.ts, --skill pi/skills, --append-system-prompt pi/AGENTS.md + personas)
# explicit verildigi icin AYNEN yuklenir. false -> global her sey tekrar sizar.
PI_ISOLATED=true

# Faz 3: Speaker-ID (ses tanima) — kapaliyken davranis Faz 2 ile AYNI.
# Yollar worker/ kokune gore relative (agent.py cwd = worker/).
SPEAKER_ID_ENABLED=false
SPEAKER_MODEL_PATH=models/campplus.onnx
SPEAKER_MODEL_ID=campplus_zh_en_advanced_v1
SPEAKER_DB=data/speakers.db
SPEAKER_THRESHOLD=0.45
SPEAKER_MARGIN=0.05
# --- AS-norm skor kalibrasyonu (konusmaci ayrimi) ---
# Ham-kosinus + sabit-esik ev sahibi Ayhan ile esi Havva'yi AYIRAMADI (offline olcum:
# marj +0.14, gurultude eksiye dondu). AS-norm cohort'a gore skoru normalize eder:
# herkese benzeyen ses cezalandirilir -> kisiler-arasi karsilastirilabilir; olcumde marj
# +2.0'a cikti, capraz-kisi belirgin NEGATIF oldu. Deney: experiments/speaker-asnorm/.
# GUVENLI GERI-DUSUS: cohort yok / kapali / dim uyusmazsa ham-kosinus davranisina duser.
SPEAKER_ASNORM_ENABLED=true
# Cohort gommeleri (N x dim, L2-norm yabanci sesler). DIKKAT: cohort ile CANLI encoder
# AYNI model olmali. Mevcut cohort WeSpeaker/256; canli model campplus.onnx/192 ->
# UYUSMAZ, AS-norm otomatik kapanip ham-kosinuse duser. AS-norm'u canli acmak icin
# ya WeSpeaker/256 encoder'a gecilmeli ya da 192-dim cohort uretilmeli.
SPEAKER_ASNORM_COHORT=models/asnorm_cohort.npy
# top-K cohort skoru (deneyde d-prime tepesi K=40, cohort N=120).
SPEAKER_ASNORM_K=40
# ESIK/MARJ AS-NORM OLCEGINDE (ham 0-1 DEGIL, ~[-14,+8]). Asagidakiler deney verisine
# dayali BASLANGIC TAHMINI, CANLIDA AYARLANACAK. Deney: ayni-kisi medyan +0.43..+5.1,
# capraz-kisi -1.6..-4.6, yabanci/cohort -5..-8; ama ayni-kisi bazi pencereler negatif
# (min -3.2). Esik -1.0: ayni-kisiyi kabul, capraz/yabanciyi ret dengesi (biraz katti).
SPEAKER_ASNORM_THRESHOLD=-1.0
# Marj (best-second) AS-norm olceginde; ayni-vs-capraz ayrimi ~+2.0 oldugu icin 1.0
# net kazanan ister. Bu da TAHMIN, canlida ayarlanacak.
SPEAKER_ASNORM_MARGIN=1.0
SPEAKER_MIN_SECONDS=1.0
SPEAKER_ENROLL_MIN_SECONDS=4.0
# COK-ORNEKLI KAYIT: kayit diyalogu boyunca ses penceresi biriktirilir, aykirilar
# atilir, yalniz tutarli CEKIRDEK yazilir. Eskiden yalniz 2 pencere yazilirdi →
# centroid zayif dogup auto-learn ile kayiyordu (olculdu: kirlenmis centroid ↔
# gercek centroid = 0.753; auto-learn orneklerinin 15/109'u esigin ALTINDA).
# Toplama ust siniri (bellek/hesap siniri).
SPEAKER_ENROLL_MAX=24
# Cekirdek bundan kucukse KAYIT YOK ("biraz daha konus" denir). Kotu kayit
# yapmaktansa kayit yapmamak yegdir.
SPEAKER_ENROLL_MIN_CORE=3
# Cekirdek uyeligi: en merkezi pencereye (seed) bu kadar benzeyenler kalir.
# DIKKAT — 0.60 OLCULMUS DEGIL, ihtiyatli bir TAHMIN (0.45 tanima esiginin ustunde
# ama ayni-kisi pencerelerini elemeyecek kadar altinda). Her kayitta basilan
# "kayit olcumu" INFO satiri (cekirdek-ici min/ort/medyan/maks) tam da bu sayiyi
# VERIDEN turetmek icin var — yeterli kayit birikince duzeltilecek.
SPEAKER_ENROLL_CORE_MIN=0.60
# Toplayicinin yoklama araligi (sn). speaker_tap ~1 sn'de bir pencere uretiyor.
SPEAKER_ENROLL_POLL_S=0.3
# EMNIYET AGI: kayit sihirbazini MODEL suruyor; model tool'u N tur boyunca HIC
# cagirmazsa kod devreye girip ismi deterministik sorar (ayni yazma kapisi). Canlida
# model "kaydettim" deyip kaydetmemisti (2026-07-17). N=5 bir YARGI: saglikli sihirbaz
# tool'u ~5. turda cagirir (riza->isim->ses->onay->tool), ag ancak 6. turda konusur ->
# calisan akisi kesmez. Ag yalniz kaydolmak ISTEYENE acilir (misafir sohbetini
# zorlamaz); "istemiyorum" diyene bir daha sorulmaz.
SPEAKER_ENROLL_NET_TURNS=5
# Enroll koruması: yeni kişi açmadan önce ses mevcut kişilere benziyor mu?
#   skor >= SPEAKER_THRESHOLD          → yeni kişi AÇMA, mevcut kişiye örnek ekle
#   SPEAKER_MERGE_LOW <= skor < eşik   → "Sen X misin?" diye sor
#   skor <  SPEAKER_MERGE_LOW          → gerçekten yeni kişi
SPEAKER_MERGE_LOW=0.35
# Centroid'de enroll ornekleri grubunun payi (auto-learn grubu = 1 - bu deger).
# Ornek SAYISINDAN bagimsiz: 100 auto-learn bile 2 enroll'u bogamaz.
# 0.7 = simulasyonda agir kirlenme altinda yabanciyi esigin altinda tutan EN DUSUK
# deger; 0.9 uyumu neredeyse olduruyor (auto-learn kapali gibi), 0.5 arizayi
# tam kapatmiyor. Yukselt = kimlik saglam ama nezle/mikrofon degisimine az uyum.
SPEAKER_ENROLL_WEIGHT=0.7
# Kacis alarmi: enroll capasina SPEAKER_THRESHOLD'dan uzak auto-learn orani bunu
# asarsa WARNING (= kume bolundu, yabanci girmis olabilir). Sessiz kayma yok.
# 0.10: canli kirlenmis DB %14 -> yanar; saglikli/uyum simulasyonu %0 -> yanmaz.
# Aradaki tam kesim noktasi yargi (olculen iki uc: 0.00 ve 0.14).
SPEAKER_DRIFT_WARN_FRAC=0.10
# Artımlı öğrenme (opsiyonel, default kapalı): yüksek güvenli tanımada centroid'i besle
SPEAKER_LEARN_ENABLED=false
SPEAKER_LEARN_MIN_SCORE=0.60
SPEAKER_LEARN_MAX_PER_SESSION=2
# Kisi basina KALICI auto-learn tavani (DB'ye bakar). Dolunca en eski auto-learn
# ornegi duser (FIFO); voice-enroll ornekleri ASLA silinmez. 0 = auto-learn kapali.
# Oturum sayaci yetmez: her LiveKit oturumu yeni surec = sayac sifirlanir.
SPEAKER_LEARN_MAX_TOTAL=20
SPEAKER_LEARN_COOLDOWN_S=60

# Wake word ("konusma penceresi"): sistem surekli acik, STT her seyi yazar ama
# agent normalde UYUR (cevap vermez). WAKE_WORD duyunca uyanir; bu turdan itibaren
# cevap verir. WAKE_WINDOW_SECONDS sessizlikten sonra tekrar uyur (her etkilesim
# pencereyi sifirlar). WAKE_ENABLED=false -> gate yok (her turda cevap, eski davranis).
WAKE_ENABLED=true
WAKE_WORD=candan
WAKE_WINDOW_SECONDS=15
# Fuzzy/fonetik wake toleransi: Whisper izole "candan"i tutarli sekilde YANLIS
# ceviriyor ("John Don", "John Donne", "Can dan", "Kandan"...) -> wake acilmiyor.
# Bu varyantlar SADECE izole-kisa metne uygulanir (<=2 kelime & <=12 karakter);
# cumle icinde fuzzy UYGULANMAZ (yanlis-pozitif olmasin). Virgulle ayir. Izole wake
# kasitli + dusuk maliyet (sadece can + kisa uyanma) oldugu icin tolerans guvenli.
WAKE_VARIANTS=candan,kandan,canden,candon,johndon,johndonne,jondon,candam

# Paralel erken-wake dinleyici (opsiyonel, additive). Ana AgentSession STT'si tum
# cumleyi bekler; bu acikken mic track'e ayri bir silero-VAD + kisa-pencere Whisper
# baglanir, "candan" duyulur duyulmaz brain.wake_now() ile can HEMEN calar (~200-270ms
# whisper roundtrip). KAPALIYKEN davranis AYNI (bu ek/erken bir yol). Sadece uyurken
# transcribe eder (uyanikken ana STT yeterli). WAKE_STT_WINDOW = erken pencere (sn);
# fizibilitede >=1.0s guvenilir, 0 false-positive olcuLdu.
# WAKE_STT_MAX_SECONDS = segmentin yalnizca ILK bu kadar saniyesi wake taramasina girer.
# Wake kelimesi cumlenin BASINDA soylenir; gerisini Whisper'a vermek saf GPU israfi
# (9 sn'lik cumle eskiden ~40 sn ses isletiyordu). Gerekirse buyutulebilir.
WAKE_STT_ENABLED=false
WAKE_STT_WINDOW=1.5
WAKE_STT_MAX_SECONDS=4.0

# Sohbeti sifirlama ("Candan, yeni sohbet baslat") + web UI "Yeni sohbet" butonu.
# Ikisi de AYNI yola iner (PiBrain.new_session): eski sessions/<...>.jsonl'in header
# id'si dondurulur (dosya SILINMEZ, diskte/panoda kalir) + ayni kisi/persona ile taze
# pi sureci dogar. Hafiza (memory/ — memory_add/soul_add) KORUNUR; sifirlanan yalniz
# SOHBET gecmisi. Guest dahil herkese serbest.
#
# NEDEN model tool'u DEGIL, wake word gibi deterministik ifade eslesmesi: olculdu —
# model "bundan sonra kisa cevap ver" gibi UYGULANABILIR gorunen talimatlarda tool'u
# CAGIRMIYOR (soul_add 0/8), dogrudan uyguluyup geciyor. "Yeni sohbet baslat" ayni
# sinifta → tool'a baglansaydi model "tamam, baslattim" der ama HICBIR SEY olmazdi.
# Bu yuzden eslesme transkript uzerinde, pi'ya prompt GITMEDEN yapilir.
#
# RESET_PHRASES: virgulle ayrilmis ifadeler. Eslesme aksan/buyuk-kucuk/noktalama
# duyarsiz; Turkce noktasiz-i ('sifirla' ~ 'sıfırla') katlanir; 2 karakter STT sapmasina
# tolerans var. YANLIS-POZITIF korumasi: yalnizca KISA/kasitli sozde (<=7 kelime) aranir
# → "dun sana yeni sohbet baslat demistim" TETIKLEMEZ (asil koruma kelime sayisi degil,
# TUM cumlenin ifadeye olan mesafesi).
# Tolerans 1 -> 2 NEDEN: "baslat" -> "basladi" STT kazasi DEGIL, Turkce'de yapisal (emir
# kipi ile gecmis zaman tek-iki harfle ayrisir). Olculdu: "yeni sohbet basladi" mesafe 2
# idi -> tolerans 1 ile ISKALANDI, metin LLM'e gitti, model sifirlamadan "yaptim" dedi.
RESET_ENABLED=true
RESET_PHRASES=yeni sohbet başlat,yeni sohbete başla,yeni sohbet,sohbeti sıfırla,sohbeti resetle,geçmişi sıfırla,geçmişi temizle,sohbeti temizle,yeni konuşma başlat,baştan başla,yeni oturum aç,yeni oturum başlat,oturumu yenile,oturumu sıfırla,yeni sayfa aç
# Sifirlama sonrasi sesli onay (kullanici komutun ISLEDIGINI duysun).
RESET_ACK=Tamam, yeni sohbet başlattım. Seni dinliyorum.
RESET_FAIL=Şu anda sohbeti sıfırlayamadım, sonra tekrar deneyelim.
# YAKIN-ISKA: metin sifirlamaya BENZIYOR ama tam eslesmiyor (mesafe 3-4) -> LLM'e
# GITMEZ; Candan deterministik olarak SORAR, onay gelince kod YURUTUR. Boylece modelin
# "yaptim" diye yalan soyleme yolu kapanir. Onay bir sonraki turda beklenir: evet/olur/
# tamam -> sifirla; hayir/yok/bosver -> vazgec; baska bir sey -> durum duser, soz normal
# akisa gider (kullanici "evet" demeye mecbur birakilmaz).
RESET_CONFIRM_ASK=Yeni sohbet başlatmamı mı istiyorsun?
RESET_CONFIRM_NO=Tamam, devam ediyoruz.

# Log gürültüsü kontrolü: 'dev' modu varsayılan DEBUG basar + bazı loglar her
# chunk/pencerede tekrarlanır (ör. speaker-tap "sessiz pencere atlandı"). Varsayılan
# davranış: seviye INFO'ya çekilir + tekrarlayan aynı log LOG_DEDUPE_SECONDS içinde
# yalnızca ilk kez basılır (log_utils.DedupeFilter). Teşhis kaybolmaz: pencere dolunca
# yine basılır, kaç tekrarın bastırıldığı da eklenir.
# WORKER_VERBOSE_LOGS=true  -> eski/ham davranış: DEBUG seviye + dedupe tamamen kapalı.
WORKER_VERBOSE_LOGS=false
# WORKER_LOG_LEVEL=INFO     -> WORKER_VERBOSE_LOGS kapalıyken kullanılan seviye.
# LOG_DEDUPE_SECONDS=30     -> aynı log art arda kaç sn içinde bir kez basılsın.

# Log DOSYASI: terminalde akan her şey ayrıca bu dosyaya da yazılır (terminal çıktısı
# AYNEN sürer — dosya EK hedef). Amaç: logu terminalden kopyalamaya gerek kalmasın.
# Her BAŞLATMADA dosya sıfırlanır (truncate) — bayat log birikmez.
# Tüm logger'lar (livekit.agents, worker.*, pi_brain, omnivoice_tts ...) düşer; job
# alt-süreçlerinin logları da IPC ile ana sürece akıp aynı dosyaya yazılır (satırda
# pid=... hangi job olduğunu söyler). Traceback'ler TAM yazılır.
# Tanımsız -> worker/logs/agent.log (göreli yol worker/ dizinine göre çözülür).
# AGENT_LOG_FILE=""         -> dosyaya HİÇ yazma (yalnız terminal).
# AGENT_LOG_FILE=logs/agent.log

# ── Proaktif ajan (hatırlatma / bitmiş iş) ────────────────────────────────────
# Hatırlatmaları pi extension (pi/extensions/family-memory) memory/events.db'ye YAZAR;
# worker heartbeat'i vakti geleni okur ve KENDİ BAŞLATARAK seslenir:
#   "Ayhan?" → kullanıcı yanıt verirse → hatırlatmayı iletir (delivered).
#   Cevap yoksa 1 kez daha seslenir, sonra pending'e döner (attempts++) ve RETRY sonra
#   tekrar dener. Kullanıcı KONUŞUYORSA erteler; odada YOKSA hiç seslenmez (pending kalır);
#   UYKUDAYKEN de seslenir (uyku susturmaz).
# PROACTIVE_TICK_SECONDS=20     -> heartbeat periyodu
# PROACTIVE_REPLY_TIMEOUT=8     -> seslenmeden sonra onay için beklenen süre (sn)
# PROACTIVE_ACK_SETTLE_SECONDS=6 -> onay sözünün BİTMESİ için üst sınır: VAD "konuşuyor"
#                                  der demez konuşmaya başlarsak hatırlatma barge-in ile
#                                  kesilir; final transkript gelene kadar bekleriz
# PROACTIVE_RETRY_SECONDS=300   -> cevapsız kalan hatırlatma bu kadar sonra tekrar denenir
# PROACTIVE_LATE_HOURS=12       -> bundan geç iletilen hatırlatma "geçmiş" diye belirtilir
# CANDAN_TZ=Europe/London       -> duvar saati çözümü (due_at'i KOD hesaplar, model değil)
# EVENTS_DB=                    -> olay deposu yolu (varsayılan: <MEM_DIR>/events.db)
# MEM_DIR=                      -> hafıza kökü (test izolasyonu; varsayılan: repo memory/)

# ── Konsolidasyon (bağlam şişmesi) ───────────────────────────────────────────
# profile.md + family.md HER TURDA modele enjekte edilir (bağlam ↔ gecikme ≈ 2.4 ms/KB).
# Sınır aşılınca worker, kullanıcı SESSİZKEN pi'ya sessiz bir tur açar → memory_consolidate:
# kalıcı gerçekler dosyada kalır, olaylar notes/'a iner (notes context'e girmez, FTS'te aranır).
# MEM_CONTEXT_LIMIT_BYTES=2048        -> profile.md / family.md sert sınırı
# CONSOLIDATE_COOLDOWN_SECONDS=86400  -> dosya başına günde en fazla 1 konsolidasyon

# ── Pano (oturum dökümü + salt-okunur hafıza) ────────────────────────────────
#   python3 tools/dashboard.py  → http://127.0.0.1:8765
