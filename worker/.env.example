# worker/.env örneği — kopyala: `cp .env.example .env` ve gerçek değerleri gir.
# LiveKit (oracle-stage — web ile AYNI key/secret)
LIVEKIT_URL=wss://mate-livekit.drascom.uk
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
MATE_LIVEKIT_ROOM=candan-lite-dev

# STT/TTS (.25 GPU kutusu — mesh IP)
STT_HOST=192.168.0.25
STT_PORT=10300
TTS_HOST=192.168.0.25
TTS_PORT=8808
MATE_LANGUAGE=tr

# Beyin: pi CLI, warm `--mode rpc` subprocess (docs/pi-brain-design.md).
# HTTP /v1 YOK — port gerekmez. Persona/skill/memory local pi/ + sessions/ ile.
PI_PERSONA_DIR=pi/personas
PI_SKILLS_DIR=pi/skills
PI_SESSION_DIR=sessions
PI_DEFAULT_PERSONA=candan
# Model pinlenmeli: global varsayilan gpt-5.6-luna rpc'de bozuk ("Model not found").
PI_MODEL=openai-codex/gpt-5.6-terra
